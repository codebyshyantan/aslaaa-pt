{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "types": [
      "vite/client"
    ],
    "baseUrl": "./src",
    "paths": {
      "@contracts/*": [
        "../../api/src/contracts/*"
      ],
      "@/*": [
        "*"
      ]
    }
  },
  "include": [
    "src",
    "../api/src/contracts"
  ]
}
